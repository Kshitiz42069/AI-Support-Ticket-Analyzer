# MongoDB Configuration
# Replace with your actual MongoDB username and password

username=your_mongodb_username
password=your_mongodb_password

MONGO_URI=
# Example for MONGO_URI:
# mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
appName=Cluster0
DB_NAME=AITicketGenerator


# JWT Configuration

# Replace with your own secure secret key
SECRET_KEY=your_super_secret_jwt_key

# JWT Algorithm
ALGORITHM=HS256

# Access token expiry time in seconds
ACCESS_TOKEN_EXPIRE=1200

# Gemini API key
# Get a free key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key